<Window x:Class="CalculatorStudy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalculatorStudy"
        mc:Ignorable="d"
        Title="Calculator" Height="450" Width="800">
    <Window.Resources>

        <!-- Кнопка цифры -->
        <Style x:Key="CalcButton" TargetType="Button">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="8" Background="#2D2D2D">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка оператора -->
        <Style x:Key="OpButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
            <Setter Property="Foreground" Value="#FF9500"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="8" Background="#3A2E1E">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#4A3A25"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FF9500"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка действия (AC, ±, %) -->
        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="8" Background="#A5A5A5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#BFBFBF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#808080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
            <RowDefinition Height="64"/>
            <RowDefinition Height="64"/>
            <RowDefinition Height="64"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Дисплей -->
        <Border Grid.Row="0" Grid.ColumnSpan="4" Grid.Column="0"
                Background="#1E1E1E" Padding="10,0" CornerRadius="10,10,10,10">
            <StackPanel VerticalAlignment="Bottom">
                <TextBlock x:Name="ExpressionDisplay"
                           Text="" Foreground="#888888"
                           FontSize="16" HorizontalAlignment="Right"/>
                <TextBlock x:Name="MainDisplay"
                           Text="0" Foreground="White"
                           FontSize="48" FontWeight="Light"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>

        <!-- Строка 1 -->
        <Button Grid.Row="1" Grid.Column="0" Content="AC" Style="{StaticResource ActionButton}" Click="Btn_Click"/>
        <Button Grid.Row="1" Grid.Column="1" Content="±"  Style="{StaticResource ActionButton}" Click="Btn_Click"/>
        <Button Grid.Row="1" Grid.Column="2" Content="%"  Style="{StaticResource ActionButton}" Click="Btn_Click"/>
        <Button Grid.Row="1" Grid.Column="3" Content="÷"  Style="{StaticResource OpButton}"     Click="Btn_Click"/>

        <!-- Строка 2 -->
        <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource CalcButton}" Click="Btn_Click" RenderTransformOrigin="0.527,0.465"/>
        <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="2" Grid.Column="3" Content="×" Style="{StaticResource OpButton}"   Click="Btn_Click"/>

        <!-- Строка 3 -->
        <Button Grid.Row="3" Grid.Column="0" Content="4" Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="3" Grid.Column="1" Content="5" Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="3" Grid.Column="2" Content="6" Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="3" Grid.Column="3" Content="−" Style="{StaticResource OpButton}"   Click="Btn_Click"/>

        <!-- Строка 4 -->
        <Button Grid.Row="4" Grid.Column="0" Content="1" Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="4" Grid.Column="1" Content="2" Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="4" Grid.Column="2" Content="3" Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="4" Grid.Column="3" Content="+" Style="{StaticResource OpButton}"   Click="Btn_Click"/>

        <!-- Строка 5 -->
        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                Content="0" Style="{StaticResource CalcButton}"
                HorizontalContentAlignment="Left" Padding="22,0,0,0"
                Click="Btn_Click"/>
        <Button Grid.Row="5" Grid.Column="2" Content="." Style="{StaticResource CalcButton}" Click="Btn_Click"/>
        <Button Grid.Row="5" Grid.Column="3" Content="=" Style="{StaticResource OpButton}"   Click="Btn_Click"/>

    </Grid>
</Window>
